{
  "name": "turbobujias-monorepo",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "next lint",
    "sync:inventory": "node scripts/sync-inventory.mjs",
    "check:inventory": "node scripts/sync-inventory.mjs --check",
    "import:inventory": "python backend/scripts/import_inventory_from_excel.py",
    "dev:backend": "npm --prefix backend run dev",
    "start:backend": "npm --prefix backend run start",
    "dev:frontend": "npm --prefix turbobujias-web run dev",
    "build:frontend": "npm --prefix turbobujias-web run build",
    "start:frontend": "npm --prefix turbobujias-web run start",
    "dev:chatbot": "node scripts/dev-stack.mjs --only chatbot --chatbot local",
    "dev:all": "node scripts/dev-stack.mjs",
    "dev:all:remote-chatbot": "node scripts/dev-stack.mjs --chatbot remote",
    "dev:all:local-chatbot": "node scripts/dev-stack.mjs --chatbot local",
    "dev:help": "node scripts/dev-stack.mjs --help"
  },
  "dependencies": {
    "@gradio/client": "^2.4.1",
    "axios": "^1.6.8",
    "html5-qrcode": "^2.3.8",
    "next": "15.5.15",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-redux": "^9.1.1",
    "@reduxjs/toolkit": "^2.2.3"
  },
  "devDependencies": {
    "eslint": "^8.57.0",
    "eslint-config-next": "15.5.15"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
