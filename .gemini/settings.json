{
    "mcpServers": {
        "huggingface": {
            "url": "https://huggingface.co/mcp?login&mix=proxy",
            "headers": {
                "Authorization": "Bearer ${HF_TOKEN}"
            }
        },
        "github": {
            "command": "docker",
            "args": [
                "run",
                "-i",
                "--rm",
                "-e",
                "GITHUB_PERSONAL_ACCESS_TOKEN",
                "ghcr.io/github/github-mcp-server:latest"
            ],
            "env": {
                "GITHUB_PERSONAL_ACCESS_TOKEN": "${GITHUB_TOKEN}"
            }
        }
    }
}
