# Turbobujias — Environment Variables Template
# 
# INSTRUCTIONS:
# 1. Copy this file: cp .env.example .env
# 2. Fill in YOUR values in .env (NOT this file)
# 3. NEVER commit .env to git
# 4. Add .env to .gitignore (already done)

# ═══════════════════════════════════════════════════════
# SUPABASE (Vector DB & Authentication)
# ═══════════════════════════════════════════════════════
SUPABASE_URL=https://your-project-id.supabase.co
SUPABASE_ANON_KEY=your_anon_key_here
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key_here
SUPABASE_DB_URL=postgresql://user:password@db.your-project-id.supabase.co:5432/postgres
SUPABASE_JWT_SECRET=your_jwt_secret_here
SUPABASE_JWKS_URL=https://your-project-id.supabase.co/auth/v1/jwks

# ═══════════════════════════════════════════════════════
# LLM PROVIDERS (Choose one as PRIMARY)
# ═══════════════════════════════════════════════════════

# GitHub Models (Recommended for free tier)
LLM_PROVIDER=github
GITHUB_TOKEN=your_github_token_here
GITHUB_MODELS_MODEL=openai/gpt-4o
GITHUB_MODELS_ORG=
GITHUB_TIMEOUT_SECONDS=10
GITHUB_MAX_TOKENS=600

# Google Gemini (Free tier available)
GEMINI_API_KEY=your_gemini_api_key_here
GEMINI_MODEL=gemini-2.0-flash-lite
GEMINI_TIMEOUT_SECONDS=12
GEMINI_TEMPERATURE=0.2
GEMINI_TOP_P=0.9
GEMINI_MAX_OUTPUT_TOKENS=384
GEMINI_FALLBACK_ENABLED=true

# Hugging Face (Inference API)
HF_TOKEN=your_huggingface_token_here
HF_MODEL_REPO_ID=mistralai/Mistral-7B-Instruct-v0.2
HF_MAX_NEW_TOKENS=384
HF_TIMEOUT_SECONDS=20

# ═══════════════════════════════════════════════════════
# GRADIO / CHATBOT UI
# ═══════════════════════════════════════════════════════
GRADIO_SERVER_NAME=0.0.0.0
GRADIO_SERVER_PORT=7860
GRADIO_SHARE=false
GRADIO_MOUNT_PATH=/
LOG_LEVEL=INFO

# ═══════════════════════════════════════════════════════
# BACKEND API (Node.js)
# ═══════════════════════════════════════════════════════
PORT=3001
BACKEND_PUBLIC_URL=http://localhost:3001
FRONTEND_PUBLIC_URL=http://localhost:3000
CHATBOT_PUBLIC_URL=https://sjhallo07-turbobujias-fullstack.hf.space/chatbot

# ═══════════════════════════════════════════════════════
# CORS & SECURITY
# ═══════════════════════════════════════════════════════
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000,http://localhost:3002
AUTH_SESSION_SECRET=your_random_secret_here_min_32_chars
AUTH_SUPERADMIN_BOOTSTRAP_PASSWORD=your_secure_password_here
AUTH_SUPERADMIN_EMAILS=your_email@example.com,another@example.com
AUTH_SUPERADMIN_USERNAMES=username1,username2

# ═══════════════════════════════════════════════════════
# THIRD-PARTY OAUTH (Optional)
# ═══════════════════════════════════════════════════════
# GOOGLE_CLIENT_ID=
# GOOGLE_CLIENT_SECRET=
# GOOGLE_CALLBACK_URL=http://localhost:3001/auth/google/callback

# ═══════════════════════════════════════════════════════
# PAYMENTS (Optional)
# ═══════════════════════════════════════════════════════
# MERCADOPAGO_ACCESS_TOKEN=
# PAYPAL_CLIENT_ID=
# PAYPAL_CLIENT_SECRET=
# PAYPAL_RECEIVER_EMAIL=

# ═══════════════════════════════════════════════════════
# VENEZUELA-SPECIFIC (Exchange Rates, Social)
# ═══════════════════════════════════════════════════════
FALLBACK_EXCHANGE_RATE=36.50
FALLBACK_EUR_EXCHANGE_RATE=39.50
EXCHANGE_RATE_CACHE_TTL_HOURS=24

# BCV API (Venezuelan Central Bank)
BCV_API_URL=https://www.bcv.org.ve
BCV_ALLOW_INSECURE_TLS=true

# Social URLs (for frontend links)
WHATSAPP_URL=https://api.whatsapp.com/send/?phone=584244342107
INSTAGRAM_URL=https://www.instagram.com/turbobujias/
MERCADOLIBRE_URL=https://www.mercadolibre.com.ve
BINANCE_PAY_URL=https://pay.binance.com/

# ═══════════════════════════════════════════════════════
# HuggingFace Spaces
# ═══════════════════════════════════════════════════════
HF_SPACE_URL=https://sjhallo07-turbobujias-fullstack.hf.space
DATASET_VIEWER_BASE_URL=https://datasets-server.huggingface.co
DATASET_VIEWER_TIMEOUT_MS=15000

# ═══════════════════════════════════════════════════════
# MCP (Model Context Protocol) — Future Use
# ═══════════════════════════════════════════════════════
# MCP_SERVER_URL=https://your-mcp-server.com
# MCP_PROTOCOL_VERSION=2025-06-18
# MCP_AUTH_BEARER_TOKEN=
