# Simplified Dockerfile for faster iteration
# Single-stage, CPU-only PyTorch

FROM python:3.10-slim

# Install runtime dependencies
RUN apt-get update && apt-get install -y --no-install-recommends \
    ffmpeg \
    ca-certificates \
    && rm -rf /var/lib/apt/lists/*

WORKDIR /app

# Install PyTorch CPU (fast wheel)
RUN pip install --no-cache-dir \
    torch==2.2.2 \
    torchvision==0.17.2 \
    torchaudio==2.2.2 \
    -i https://download.pytorch.org/whl/cpu

# Install all dependencies
RUN pip install --no-cache-dir \
    gradio==6.13.0 \
    transformers>=5.6.2 \
    sentence-transformers>=5.4.1 \
    faiss-cpu>=1.7.4 \
    langchain>=1.2.0,<2.0.0 \
    langchain-community>=0.4.0,<0.5.0 \
    langchain-text-splitters>=1.0.0,<2.0.0 \
    huggingface-hub>=0.22.2,<1.0 \
    openai>=1.75.0 \
    openai-whisper>=20230314 \
    accelerate>=1.13.0 \
    python-dotenv>=1.0.1 \
    requests>=2.32.0 \
    uvicorn>=0.28.0 \
    pydantic>=2.0.0

# Copy app files
COPY inventory.json app.py ./

# Environment
ENV GRADIO_SERVER_NAME="0.0.0.0"
ENV GRADIO_SERVER_PORT="7860"
ENV PYTHONUNBUFFERED="1"
ENV PYTHONDONTWRITEBYTECODE="1"

EXPOSE 7860

# Default .env location (can be overridden at runtime)
ENV ENV_FILE=".env"

CMD ["python", "app.py"]
