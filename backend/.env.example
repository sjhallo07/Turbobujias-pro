PORT=3001
MERCADOPAGO_ACCESS_TOKEN=your_mp_access_token_here
PAYPAL_CLIENT_ID=your_paypal_client_id_here
PAYPAL_CLIENT_SECRET=your_paypal_client_secret_here
# The PayPal account email that should receive payments (used to validate IPN notifications)
PAYPAL_RECEIVER_EMAIL=your_paypal_email@example.com
BCV_API_URL=https://www.bcv.org.ve
# Fallback exchange rate as a numeric value (used when BCV_API_URL is unset or unreachable)
FALLBACK_EXCHANGE_RATE=36.50
